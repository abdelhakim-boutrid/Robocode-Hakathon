interface DistanceFunction {
    double distance(double[] p1, double[] p2);
    double distanceToRect(double[] p, double[] min, double[] max);
}

class SquareEuclideanDistanceFunction implements DistanceFunction {
    public double distance(double[] p1, double[] p2) {
        double d = 0;
        for (int i = 0; i < p1.length; i++) {
            double diff = p1[i] - p2[i];
            d += diff * diff;
        }
        return d;
    }
    public double distanceToRect(double[] p, double[] min, double[] max) {
        double d = 0;
        for (int i = 0; i < p.length; i++) {
            double diff = 0;
            if (p[i] > max[i]) diff = p[i] - max[i];
            else if (p[i] < min[i]) diff = min[i] - p[i];
            d += diff * diff;
        }
        return d;
    }
}

class ThirdGenMaxHeap<T> {
    private java.util.ArrayList<Double> keys = new java.util.ArrayList<Double>();
    private java.util.ArrayList<T> values = new java.util.ArrayList<T>();

    public int size() { return keys.size(); }

    public void offer(double key, T value) {
        int i = 0;
        while (i < keys.size() && keys.get(i) >= key) i++;
        keys.add(i, key);
        values.add(i, value);
    }

    public void replaceMax(double key, T value) {
        if (keys.isEmpty()) { offer(key, value); return; }
        keys.remove(0);
        values.remove(0);
        offer(key, value);
    }

    public double getMaxKey() {
        if (keys.isEmpty()) return Double.POSITIVE_INFINITY;
        return keys.get(0);
    }

    public T getMax() {
        if (values.isEmpty()) return null;
        return values.get(0);
    }
}

class ThirdGenKdTree<T> {
    private final int dimensions;
    private java.util.ArrayList<double[]> points = new java.util.ArrayList<double[]>();
    private java.util.ArrayList<T> data = new java.util.ArrayList<T>();

    public ThirdGenKdTree(int dimensions) { this.dimensions = dimensions; }
    public ThirdGenKdTree(int dimensions, int bucket) { this.dimensions = dimensions; }

    public int size() { return points.size(); }

    public void addPoint(double[] location, T value) {
        double[] copy = new double[location.length];
        System.arraycopy(location, 0, copy, 0, location.length);
        points.add(copy);
        data.add(value);
    }

    public ThirdGenMaxHeap<T> findNearestNeighbors(double[] searchPoint, int maxPointsReturned, DistanceFunction distanceFunction) {
        ThirdGenMaxHeap<T> heap = new ThirdGenMaxHeap<T>();
        int need = Math.min(maxPointsReturned, points.size());
        for (int i = 0; i < points.size(); i++) {
            double d = distanceFunction.distance(points.get(i), searchPoint);
            if (heap.size() < need) {
                heap.offer(d, data.get(i));
            } else if (d < heap.getMaxKey()) {
                heap.replaceMax(d, data.get(i));
            }
        }
        return heap;
    }
}
