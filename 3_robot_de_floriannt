package floariiiant;

import robocode.*;
import robocode.util.Utils;
import java.awt.*;
import java.util.*;
import java.util.List; // Précision pour éviter les conflits

public class RobocodeRobot extends AdvancedRobot {

    private static final double WALL_MARGIN = 80;
    private static final double RAM_DISTANCE = 60;
    private static final int GF_BINS = 31;
    private static final int GF_MIDDLE = GF_BINS / 2;
    private static final double MAX_ESCAPE_ANGLE = 0.785;

    private double enemyX, enemyY;
    private double enemyHeading, enemyVelocity;
    private double enemyAbsoluteBearing;
    private double prevEnemyEnergy = 100;
    private double prevEnemyHeading = 0;
    private double enemyDistance = 1000;

    private final List<EnemyWave> waves = new ArrayList<EnemyWave>();
    private final double[] gfStats = new double[GF_BINS];

    private double moveDirection = 1;

    private boolean isDuel() {
        return getOthers() <= 1; // Un duel, c'est quand il ne reste qu'un adversaire
    }

    @Override
    public void run() {
        setAdjustRadarForRobotTurn(true);
        setAdjustGunForRobotTurn(true);
        setAdjustRadarForGunTurn(true);

        setTurnRadarRightRadians(Double.POSITIVE_INFINITY);
        setMaxVelocity(8);

        while (true) {
            updateWaves();
            if (isDuel()) {
                doWaveSurfing();
            } else {
                doMeleeMovement();
            }
            execute();
        }
    }

    @Override
    public void onScannedRobot(ScannedRobotEvent e) {
        enemyDistance = e.getDistance();
        enemyAbsoluteBearing = getHeadingRadians() + e.getBearingRadians();
        enemyHeading = e.getHeadingRadians();
        enemyVelocity = e.getVelocity();

        enemyX = getX() + Math.sin(enemyAbsoluteBearing) * enemyDistance;
        enemyY = getY() + Math.cos(enemyAbsoluteBearing) * enemyDistance;

        double radarError = Utils.normalRelativeAngle(enemyAbsoluteBearing - getRadarHeadingRadians());
        setTurnRadarRightRadians(radarError * 2.0);

        double energyDrop = prevEnemyEnergy - e.getEnergy();
        if (energyDrop > 0.09 && energyDrop <= 3.01) {
            EnemyWave wave = new EnemyWave();
            wave.startX = enemyX;
            wave.startY = enemyY;
            wave.startTime = getTime();
            wave.bulletVelocity = 20 - 3 * energyDrop;
            wave.directAngle = enemyAbsoluteBearing + Math.PI;
            waves.add(wave);
        }
        prevEnemyEnergy = e.getEnergy();

        if (isDuel()) {
            doGFTargeting(e);
        } else {
            doMeleeTargeting(e);
        }
        
        prevEnemyHeading = enemyHeading;
    }

    private void doGFTargeting(ScannedRobotEvent e) {
        double bulletPower = calcBulletPowerDuel();
        double bulletVelocity = 20 - 3 * bulletPower;

        int bestBin = GF_MIDDLE;
        for (int i = 0; i < GF_BINS; i++) {
            if (gfStats[i] > gfStats[bestBin]) bestBin = i;
        }

        double guessFactor = (double)(bestBin - GF_MIDDLE) / GF_MIDDLE;
        int lateralDir = (enemyVelocity >= 0) ? 1 : -1;

        double aimAngle = enemyAbsoluteBearing + (lateralDir * guessFactor * MAX_ESCAPE_ANGLE);
        setTurnGunRightRadians(Utils.normalRelativeAngle(aimAngle - getGunHeadingRadians()));

        if (getGunHeat() == 0) setFire(bulletPower);
    }

    private void doMeleeTargeting(ScannedRobotEvent e) {
        double bulletPower = calcBulletPowerMelee();
        double aimAngle = Math.atan2(enemyX - getX(), enemyY - getY());
        setTurnGunRightRadians(Utils.normalRelativeAngle(aimAngle - getGunHeadingRadians()));
        if (getGunHeat() == 0) setFire(bulletPower);
    }

    private void doMeleeMovement() {
        double angle = Utils.normalRelativeAngle(enemyAbsoluteBearing - getHeadingRadians() + Math.PI / 2);
        setTurnRightRadians(angle);
        setAhead(100 * moveDirection);

        if (isNearWall(getX(), getY())) moveDirection *= -1;
    }

    private void updateWaves() {
        Iterator<EnemyWave> it = waves.iterator();
        while (it.hasNext()) {
            EnemyWave wave = it.next();
            wave.distanceTraveled = (getTime() - wave.startTime) * wave.bulletVelocity;
            if (wave.distanceTraveled > enemyDistance + 50) it.remove();
        }
    }

    private void doWaveSurfing() {
        setAhead(100 * moveDirection);
    }

    private double calcBulletPowerDuel() { return (enemyDistance < 150) ? 3.0 : 2.0; }
    private double calcBulletPowerMelee() { return 1.2; }

    private boolean isNearWall(double x, double y) {
        return x < WALL_MARGIN || x > getBattleFieldWidth() - WALL_MARGIN
                || y < WALL_MARGIN || y > getBattleFieldHeight() - WALL_MARGIN;
    }

    // CLASSE INTERNE BIEN PLACÉE
    public static class EnemyWave {
        double startX, startY, directAngle, bulletVelocity, distanceTraveled;
        long startTime;
    }
}
